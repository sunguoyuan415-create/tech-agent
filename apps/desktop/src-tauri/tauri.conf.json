{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tech-agent",
  "version": "1.0.0",
  "identifier": "dev.tech-agent.desktop",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tech-agent",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "category": "Productivity",
    "shortDescription": "Cloud Agent Platform",
    "longDescription": "Tech-agent desktop client for the cloud Agent workspace."
  }
}
